# ─── Required ───────────────────────────────────────────────────────────
# Google Gemini API key. Get one (free) at https://aistudio.google.com/apikey
GEMINI_API_KEY=replace-me

# ─── Optional ───────────────────────────────────────────────────────────
# Gemini vision model. "gemini-2.5-flash" is the recommended default —
# fast, free tier eligible, and strong at OCR. Other valid choices:
#   gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
MODEL_NAME=gemini-2.5-flash

# Maximum accepted upload size, in megabytes.
MAX_FILE_SIZE_MB=10

# HTTP port. HuggingFace Spaces requires 7860.
PORT=7860

# Deployment environment label: production | staging | development
ENVIRONMENT=production
